# ==============================================================
# B. ORACLE DATABASE CONFIGURATION
# ==============================================================
ORACLE_USER=gendba
ORACLE_PASSWORD=YourOraclePasswordHere
# Note: If running locally without Docker:
ORACLE_DSN=localhost:1521/orcl2
# Note: If running inside Docker, uncomment the line below:
# ORACLE_DSN=host.docker.internal:1521/orcl2pdb

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Ung dung
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=info
